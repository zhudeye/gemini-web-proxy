{
  "name": "gemini-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "esbuild src/server.ts --bundle --platform=node --target=node20 --outdir=dist --outbase=src --format=esm --external:undici",
    "start": "node dist/server.js",
    "test": "npm run test:run",
    "test:run": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "esbuild": "^0.25.0",
    "undici": "^7.28.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "dotenv": "^17.4.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
