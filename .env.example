NODE_ENV=production
PORT=10000

# Never commit real values. Configure these in Render Environment.
# Combined cookie string: paste the full cookie values from DevTools.
# Format: __Secure-1PSID=xxx; __Secure-1PSIDTS=yyy; __Secure-1PSIDCC=zzz
GEMINI_COOKIE="__Secure-1PSID=<paste-psid-value>; __Secure-1PSIDTS=<paste-psidts-value>; __Secure-1PSIDCC=<paste-psidcc-value>"

# Comma-separated Bearer keys accepted by this proxy.
API_KEYS=<replace-with-long-random-key-1>,<replace-with-long-random-key-2>
ALLOWED_ORIGINS=https://your-app.example,http://localhost:3000
RATE_LIMIT_PER_MINUTE=20

# Optional: override auto-discovered Gemini Web endpoint.
# GEMINI_ENDPOINT=https://gemini.google.com/_/BardChatUi/data/assistant.lamda.BardFrontendService/StreamGenerate
