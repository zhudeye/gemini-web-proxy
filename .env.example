NODE_ENV=production
PORT=10000

# Never commit real values. Configure these in Render Environment.
GEMINI_COOKIE=<paste-secure-1psid-cookie-value>
GEMINI_COOKIE_TS=<paste-secure-1psidts-cookie-value>
GEMINI_COOKIE_CC=<optional-secure-1psidcc-cookie-value>
GEMINI_ENDPOINT=https://gemini.google.com/_/example/manual-endpoint

# Comma-separated Bearer keys accepted by this proxy.
API_KEYS=<replace-with-long-random-key-1>,<replace-with-long-random-key-2>
ALLOWED_ORIGINS=https://your-app.example,http://localhost:3000
RATE_LIMIT_PER_MINUTE=20
